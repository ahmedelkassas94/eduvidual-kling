# Copy this file to .env and fill in your API keys.
# .env is gitignored and will not be committed.

# OpenAI (planner / LLM)
OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4o

# Google Gemini (image generation, Veo, and planner: script + prompts)
# Use a key with NO application restrictions (no IP/referrer limits) so it works from Cursor and CI.
GEMINI_API_KEY=your_gemini_key_here
IMAGE_MODEL=gemini-3-pro-image-preview
# Planner: Gemini 2.5 writes script + T2I prompts; Claude writes I2V (movement_prompt) only
# PLANNER_MODEL=gemini-2.5-flash

# Anthropic Claude (I2V movement_prompt only) — default: Claude 3.5 Sonnet
ANTHROPIC_API_KEY=your_anthropic_key_here
# CLAUDE_MODEL=claude-3-5-sonnet-20241022

# Alibaba DashScope (WAN I2V) - optional
DASHSCOPE_API_KEY=your_dashscope_key_here
DASHSCOPE_REGION=sg

# Cost control: require typing APPROVE at each step (no auto-approve)
# APPROVE_ALL_INGREDIENTS=1

# Image QA: run every generated image through Gemini "lens" (logic + context + science)
# and iteratively regenerate with a corrected prompt until usable.
IMAGE_LENS_ENABLED=1
IMAGE_LENS_MAX_ATTEMPTS=3

# Before each image generation: Gemini text reviser refines the draft prompt (logic + script fit + science).
IMAGE_PROMPT_PRE_REVISER_ENABLED=1

# Video backend: veo, wan, or kling (I2V = image-to-video)
VIDEO_BACKEND=kling
# I2V model: Veo 3.1 standard (quality). Optional: set to veo-3.1-fast-generate-preview for faster generation.
VEO_MODEL=veo-3.1-generate-preview

# Kling 3.0 direct via klingai.com (Kling image-to-video)
# Auth usually uses a bearer token.
KLINGAI_API_KEY=your_klingai_api_key_here
# Optional alternative auth fields (if your provider exposes access+secret separately).
# Some backends still expect a single token; this repo will combine them as `access:secret`.
# KLINGAI_ACCESS_KEY=your_access_key_here
# KLINGAI_SECRET_KEY=your_secret_key_here
KLINGAI_API_BASE_URL=https://api.klingai.com
KLINGAI_IMAGE2VIDEO_ENDPOINT=/klingai/v1/videos/image2video
KLINGAI_MODEL_NAME=klingai/kling-v3.0-i2v
KLINGAI_MODE=pro
KLINGAI_ASPECT_RATIO=16:9

# Backwards compat (repo previously used Kling via fal.ai):
# FAL_KEY=your_fal_key_here

# First+Last architecture: last frame is always I2I (first frame + reviser description) for continuity.
# Scientific revision (OpenAI Vision) checks first+last frames before I2V; corrections applied via I2I if needed.

# Post-stitch audio (GPT + ElevenLabs)
# ELEVENLABS_API_KEY=your_elevenlabs_key_here
# POST_STITCH_AUDIO_ONLY=1
